# build output (committed deliberately at release packaging, M10)
/bin/
*.o
*.obj
*.exe.stackdump

# nix
/result
/result-*
/.direnv/

# agent-harness local settings
/.claude/

# scratch
/tmp/
/tests/out/

# time-machine ring exports (the scrubber's "save .ctrace"; share via
# tests/traces or the feed, don't commit by accident)
/projects/*/ring-f*.ctrace

# per-machine video options (the options menu's saved resolution / ui scale /
# fullscreen — cm.view.save_video); machine-local, like knobs.dat / map.dat
/projects/*/video.dat

# per-machine player rebinds (the options menu's controls page, A4/D084 —
# cm.input.save_binds); machine-local like video.dat
/projects/*/input.dat

# the editor shell's per-project session + undo journals (R3, D050):
# unsaved-persists state is per-machine, never in the repo
.ed/
.recent.dat

# cosmic3d fork: staged CC0/CC-BY packs (230MB; assets/README.md documents
# contents + re-fetch; per-pack LICENSE-NOTE.txt inside)
/assets/*
!/assets/README.md

# prototype build artifacts (out/*.png money shots ARE committed)
/proto/proto
/proto/gpu_proto
/proto/out/*.c3dd
